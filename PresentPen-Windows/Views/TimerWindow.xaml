<Window x:Class="PresentPen.Views.TimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Timer"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized">

    <Grid x:Name="RootGrid">
        <!-- 검은색 배경 -->
        <Rectangle x:Name="BackgroundRect" Fill="#F0000000"/>

        <!-- 상단 모드 인디케이터 -->
        <Border Background="#D94CAF50"
                CornerRadius="20"
                Padding="20,8"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,40,0,0">
            <TextBlock Text="⏱ 타이머"
                      Foreground="White"
                      FontSize="16"
                      FontWeight="SemiBold"/>
        </Border>

        <!-- 중앙 시간 표시 -->
        <StackPanel HorizontalAlignment="Center"
                   VerticalAlignment="Center">
            <TextBlock x:Name="TimerDisplay"
                      Text="05:00"
                      FontSize="200"
                      FontWeight="Bold"
                      Foreground="White"
                      FontFamily="Consolas"
                      HorizontalAlignment="Center"/>

            <!-- 프리셋 안내 -->
            <TextBlock x:Name="PresetLabel"
                      Text="[1] 1분   [3] 3분   [5] 5분   [0] 10분"
                      FontSize="18"
                      FontFamily="Consolas"
                      Foreground="#CCFFFFFF"
                      HorizontalAlignment="Center"
                      Margin="0,20,0,0"/>

            <!-- 상태 안내 -->
            <TextBlock x:Name="InfoLabel"
                      Text="스크롤/↑↓: 시간 조절 | Space/Enter: 시작 | ESC: 종료"
                      FontSize="16"
                      Foreground="#99FFFFFF"
                      HorizontalAlignment="Center"
                      Margin="0,16,0,0"/>
        </StackPanel>
    </Grid>
</Window>
