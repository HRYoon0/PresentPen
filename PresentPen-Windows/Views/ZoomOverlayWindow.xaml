<Window x:Class="PresentPen.Views.ZoomOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zoom Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowState="Maximized"
        Cursor="Cross">

    <Grid>
        <!-- 확대된 화면 이미지 -->
        <Image x:Name="ZoomImage"
               Stretch="None"
               RenderOptions.BitmapScalingMode="NearestNeighbor">
            <Image.RenderTransform>
                <ScaleTransform x:Name="ZoomTransform"
                               CenterX="0" CenterY="0"
                               ScaleX="2" ScaleY="2"/>
            </Image.RenderTransform>
        </Image>

        <!-- 스포트라이트 오버레이 (줌 내부) -->
        <Canvas x:Name="SpotlightOverlay" Visibility="Collapsed" IsHitTestVisible="False">
            <Path x:Name="SpotlightPath" Fill="#CC000000"/>
        </Canvas>

        <!-- 그리기 오버레이 (줌 내부) -->
        <Canvas x:Name="DrawOverlay" Visibility="Collapsed"
                Background="#01000000"
                MouseLeftButtonDown="DrawOverlay_MouseLeftButtonDown"
                MouseMove="DrawOverlay_MouseMove"
                MouseLeftButtonUp="DrawOverlay_MouseLeftButtonUp"/>

        <!-- 커서 하이라이트 오버레이 (줌 내부) -->
        <Canvas x:Name="CursorOverlay" Visibility="Collapsed" IsHitTestVisible="False">
            <Ellipse x:Name="ZoomCursorHighlight" Width="60" Height="60"/>
        </Canvas>

        <!-- 줌 레벨 + 기능 표시 -->
        <Border Background="#80000000"
                CornerRadius="8"
                Padding="12,6"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="20">
            <TextBlock x:Name="ZoomLevelText"
                      Text="2.0x"
                      Foreground="White"
                      FontSize="16"
                      FontWeight="SemiBold"/>
        </Border>

        <!-- 도움말 -->
        <Border x:Name="HelpBorder"
                Background="#B0000000"
                CornerRadius="8"
                Padding="12,8"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="20">
            <StackPanel>
                <TextBlock Text="마우스 휠: 확대/축소 | Ctrl+1: 줌 위에 그리기 | Ctrl+3: 커서 하이라이트 | Ctrl+4: 스포트라이트"
                          Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
                <TextBlock Text="ESC: 종료"
                          Foreground="White" FontSize="11" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
