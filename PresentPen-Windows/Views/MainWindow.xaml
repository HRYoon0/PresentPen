<Window x:Class="PresentPen.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="PresentPen"
        Width="360" Height="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="{StaticResource BackgroundBrush}"
            CornerRadius="16"
            BorderBrush="#2A2A50"
            BorderThickness="1">
        <Grid Margin="28,24,28,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 로고 + 닫기 -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="White">
                        <Run Text="Present" Foreground="{StaticResource PrimaryLightBrush}"/><Run Text="Pen"/>
                    </TextBlock>
                    <TextBlock Text="프레젠테이션 도구"
                              FontSize="12"
                              Foreground="{StaticResource TextDimBrush}"
                              Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Top">
                    <Button Style="{StaticResource ActionButton}"
                           Content="─"
                           Width="32" Height="28"
                           Padding="0"
                           FontSize="14"
                           Click="MinimizeButton_Click"/>
                    <Button Style="{StaticResource DangerButton}"
                           Content="✕"
                           Width="32" Height="28"
                           Padding="0"
                           FontSize="12"
                           Margin="4,0,0,0"
                           Click="ExitButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- 상태 카드 -->
            <Border Grid.Row="1"
                   CornerRadius="12"
                   Padding="16,12"
                   Margin="0,0,0,20">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2A2A50" Offset="0"/>
                        <GradientStop Color="#1A1A35" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Grid.Column="0"
                            Width="8" Height="8"
                            Fill="{StaticResource AccentBrush}"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="상태"
                                  FontSize="10"
                                  Foreground="{StaticResource TextDimBrush}"
                                  Margin="0,0,0,2"/>
                        <TextBlock x:Name="StatusText"
                                  Text="대기 중"
                                  FontSize="16"
                                  FontWeight="SemiBold"
                                  Foreground="White"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 기능 버튼들 -->
            <StackPanel Grid.Row="2" Margin="0,0,0,8">
                <Button Style="{StaticResource PrimaryButton}"
                       Margin="0,3"
                       Click="ZoomButton_Click">
                    <Grid Width="260">
                        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Run Text="🔍 " FontSize="16"/>
                            <Run Text="화면 확대" FontSize="14"/>
                        </TextBlock>
                        <TextBlock Text="Ctrl+1"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  FontSize="11"
                                  Foreground="{StaticResource TextDimBrush}"/>
                    </Grid>
                </Button>

                <Button Style="{StaticResource PrimaryButton}"
                       Margin="0,3"
                       Click="DrawButton_Click">
                    <Grid Width="260">
                        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Run Text="✏️ " FontSize="16"/>
                            <Run Text="그리기" FontSize="14"/>
                        </TextBlock>
                        <TextBlock Text="Ctrl+2"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  FontSize="11"
                                  Foreground="{StaticResource TextDimBrush}"/>
                    </Grid>
                </Button>

                <Button Style="{StaticResource PrimaryButton}"
                       Margin="0,3"
                       Click="TimerButton_Click">
                    <Grid Width="260">
                        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Run Text="⏱️ " FontSize="16"/>
                            <Run Text="타이머" FontSize="14"/>
                        </TextBlock>
                        <TextBlock Text="Ctrl+3"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  FontSize="11"
                                  Foreground="{StaticResource TextDimBrush}"/>
                    </Grid>
                </Button>

                <Button Style="{StaticResource PrimaryButton}"
                       Margin="0,3"
                       Click="SpotlightButton_Click">
                    <Grid Width="260">
                        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Run Text="💡 " FontSize="16"/>
                            <Run Text="스포트라이트" FontSize="14"/>
                        </TextBlock>
                        <TextBlock Text="Ctrl+4"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  FontSize="11"
                                  Foreground="{StaticResource TextDimBrush}"/>
                    </Grid>
                </Button>

                <Button Style="{StaticResource PrimaryButton}"
                       Margin="0,3"
                       Click="HighlightButton_Click">
                    <Grid Width="260">
                        <TextBlock HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Run Text="✨ " FontSize="16"/>
                            <Run Text="커서 하이라이트" FontSize="14"/>
                        </TextBlock>
                        <TextBlock Text="Ctrl+5"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  FontSize="11"
                                  Foreground="{StaticResource TextDimBrush}"/>
                    </Grid>
                </Button>
            </StackPanel>

            <!-- 구분선 -->
            <Rectangle Grid.Row="3"
                      Height="1"
                      Fill="#222240"
                      Margin="0,8,0,12"/>

            <!-- 하단 버튼 -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                       Style="{StaticResource ActionButton}"
                       Content="📖  도움말"
                       Margin="0,0,4,0"
                       Click="HelpButton_Click"/>
                <Button Grid.Column="1"
                       Style="{StaticResource ActionButton}"
                       Content="⚙️  설정"
                       Margin="4,0,0,0"
                       Click="SettingsButton_Click"/>
            </Grid>

            <!-- 제작자 정보 -->
            <TextBlock Grid.Row="5"
                      Text="제작자: 황산초등학교 윤희류"
                      FontSize="11"
                      Foreground="{StaticResource TextDimBrush}"
                      HorizontalAlignment="Center"
                      Margin="0,12,0,0"/>
        </Grid>
    </Border>
</Window>
