<Window x:Class="PresentPen.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PresentPen 도움말"
        Width="520" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Background="#2D2D2D" Padding="16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="❓" FontSize="28" VerticalAlignment="Center" Margin="0,0,12,0"/>
                <StackPanel>
                    <TextBlock Text="PresentPen" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="프레젠테이션을 위한 화면 주석 도구" FontSize="12" Foreground="Gray"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 탭 버튼 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Background="#252525" HorizontalAlignment="Center">
            <Button x:Name="Tab0" Content="단축키" Click="Tab_Click" Tag="0"
                   Background="#2196F3" Foreground="White" Width="90" Height="32" Margin="2" BorderThickness="0"/>
            <Button x:Name="Tab1" Content="그리기" Click="Tab_Click" Tag="1"
                   Background="#444" Foreground="White" Width="90" Height="32" Margin="2" BorderThickness="0"/>
            <Button x:Name="Tab2" Content="줌" Click="Tab_Click" Tag="2"
                   Background="#444" Foreground="White" Width="90" Height="32" Margin="2" BorderThickness="0"/>
            <Button x:Name="Tab3" Content="커서/스포트" Click="Tab_Click" Tag="3"
                   Background="#444" Foreground="White" Width="90" Height="32" Margin="2" BorderThickness="0"/>
            <Button x:Name="Tab4" Content="타이머" Click="Tab_Click" Tag="4"
                   Background="#444" Foreground="White" Width="90" Height="32" Margin="2" BorderThickness="0"/>
        </StackPanel>

        <!-- 콘텐츠 영역 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="20">
            <StackPanel x:Name="ContentPanel"/>
        </ScrollViewer>
    </Grid>
</Window>
